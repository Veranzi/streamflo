# ============================================
# DATABASE — Supabase / Neon / any Postgres
# ============================================
# From Supabase: Settings → Database → Connection string → URI (use the "Transaction" pooler)
# Format: postgresql://user:pass@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres?sslmode=require

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# EMAIL (for password reset, transactional notifications)
# ============================================
# If not set, reset emails are logged to the server console — fine for local dev,
# you can copy the link from the terminal. For prod use Gmail (App Password),
# Resend SMTP (smtp.resend.com:587), SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Streamflo <noreply@streamflo.co.ke>

# ============================================
# GOOGLE OAUTH (for "Continue with Google")
# ============================================
# Get credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (must match exactly):
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://yourdomain.com/api/auth/callback/google  (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# APP
# ============================================
NEXT_PUBLIC_SITE_NAME=Streamflo
NEXT_PUBLIC_WHATSAPP=254783601773

# ============================================
# EduTena integration (internal — never exposed to browsers)
# ============================================
# Gateway URL. In dev: http://localhost:3100. In prod: Railway URL.
EDUTENA_API_URL=http://localhost:3100

# Must match JWT_SECRET in edutena-backend/.env so both sides trust each other's tokens
# for the federated-exchange handshake. Keep it long and random.
JWT_SECRET=use-the-same-value-in-edutena-backend-env
